---
import BaseLayout from '../layouts/BaseLayout.astro';
import products from '../data/products.json';

const brands = [...new Set(products.map((p) => p.brand).filter(Boolean))].slice(0, 8);
const stories = [
  {
    kicker: 'Craft & heritage',
    title: 'The Seiko Cocktail: a toast to time',
    copy: 'A champagne dial, cocktail-hour light, and the quiet romance of Japanese watchmaking.',
    href: '/stories/seiko-presage-cocktail.html',
    image: '/images/watches/SRE020J1-transparent.webp',
    alt: 'Seiko Presage Cocktail SRE020J1',
  },
  {
    kicker: 'Built for the open',
    title: 'The field watch, made lighter',
    copy: 'Hamilton turns military utility into a titanium companion for everyday journeys.',
    href: '/stories/khaki-field-titanium.html',
    image: '/images/watches/H70205830-transparent.webp',
    alt: 'Hamilton Khaki Field Titanium',
  },
  {
    kicker: 'Below the surface',
    title: 'A different state of time',
    copy: 'The Khaki Navy Scuba carries clarity, confidence, and a little ocean into the everyday.',
    href: '/stories/khaki-navy-scuba.html',
    image: '/images/watches/H82365141-transparent.webp',
    alt: 'Hamilton Khaki Navy Scuba',
  },
];
---

<BaseLayout title="Watch Stories" description="Editorial watch stories for collectors and first-time buyers around the world.">
  <section class="journey-hero">
    <div class="hero-watch" aria-hidden="true"></div>
    <div class="hero-shade"></div>
    <div class="container hero-content">
      <p class="hero-kicker">A more considered way to choose a watch</p>
      <h1>Maybe the right watch is the one whose story stays with you.</h1>
      <p class="hero-intro">Discover timepieces through craft, heritage, place, and the moments they were made to accompany.</p>
      <a href="/stories/seiko-presage-cocktail.html" class="light-link">Discover the story <span>→</span></a>
    </div>
    <a href="#philosophy" class="hero-next">The journey begins <span>↓</span></a>
  </section>

  <section class="philosophy" id="philosophy">
    <div class="container philosophy-inner">
      <p class="section-kicker">The Watch Stories approach</p>
      <h2>From first glance to lasting connection.</h2>
      <p>We believe choosing a watch should feel less like scrolling through a catalogue and more like discovering a place you want to return to. First, see the watch. Then understand its world. Only then decide whether it belongs in yours.</p>
      <div class="journey-steps">
        <span>01 — See</span>
        <span>02 — Read</span>
        <span>03 — Decide</span>
      </div>
    </div>
  </section>

  <section class="stories" id="stories">
    <header class="container stories-heading">
      <p class="section-kicker">Curated stories</p>
      <h2>Timepieces with somewhere to take you.</h2>
    </header>

    {stories.map((story, index) => (
      <article class:list={['story-chapter', { reverse: index % 2 === 1 }]}>
        <a href={story.href} class="chapter-image">
          <img src={story.image} alt={story.alt} loading={index === 0 ? 'eager' : 'lazy'} />
        </a>
        <div class="chapter-copy">
          <p class="section-kicker">{story.kicker}</p>
          <h3>{story.title}</h3>
          <p>{story.copy}</p>
          <a href={story.href} class="ink-link">Read the story <span>→</span></a>
        </div>
      </article>
    ))}
  </section>

  <section class="promise">
    <div class="container promise-grid">
      <div>
        <p class="section-kicker">Why stories</p>
        <h2>Every detail, thoughtfully considered.</h2>
      </div>
      <div class="promise-list">
        <div><span>Heritage</span><p>The people, places, and ideas that shaped a watch.</p></div>
        <div><span>Character</span><p>How a watch feels in real life, beyond the specification sheet.</p></div>
        <div><span>Clarity</span><p>A buying link only after the story has helped you decide.</p></div>
      </div>
    </div>
  </section>

  <section class="brands">
    <div class="container">
      <p class="section-kicker">Stories across makers</p>
      <div class="brand-line">{brands.map((brand) => <span>{brand}</span>)}</div>
    </div>
  </section>

  <section class="closing">
    <div class="container closing-inner">
      <p class="section-kicker">Continue exploring</p>
      <h2>Your next watch may begin with a story.</h2>
      <a href="/watches" class="light-link">Explore the collection <span>→</span></a>
    </div>
  </section>
</BaseLayout>

<style>
  .container { width: min(1180px, calc(100% - 2rem)); margin: 0 auto; }
  .journey-hero {
    position: relative;
    min-height: min(860px, calc(100vh - 72px));
    overflow: hidden;
    display: flex;
    align-items: end;
    color: #fff;
    background: #34433f;
  }
  .hero-watch {
    position: absolute;
    inset: 0;
    background:
      url("/images/watches/SRE020J1-transparent.webp")
      right 10% center / auto 92% no-repeat,
      linear-gradient(105deg, #263a38 0%, #3f5651 54%, #d9ded8 54%, #eef0ec 100%);
    transform: scale(1.01);
  }
  .hero-shade { position: absolute; inset: 0; background: linear-gradient(90deg, rgba(12,24,22,.54), transparent 72%); }
  .hero-content { position: relative; z-index: 1; padding-bottom: 5rem; }
  .hero-content h1 {
    max-width: 790px;
    font-size: 5rem;
    line-height: .96;
  }
  .hero-kicker, .section-kicker {
    margin: 0 0 1.4rem;
    font-size: .7rem;
    font-weight: 600;
    letter-spacing: .18em;
    text-transform: uppercase;
  }
  .hero-intro { max-width: 570px; margin-top: 1.8rem; font-size: 1.05rem; line-height: 1.7; }
  .light-link, .ink-link {
    display: inline-flex;
    gap: 1.2rem;
    align-items: center;
    margin-top: 2rem;
    padding-bottom: .45rem;
    border-bottom: 1px solid currentColor;
    text-decoration: none;
    font-size: .76rem;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: inherit;
  }
  .hero-next {
    position: absolute;
    z-index: 2;
    left: 50%;
    bottom: 2.2rem;
    display: flex;
    gap: 1rem;
    color: #fff;
    font-size: .68rem;
    letter-spacing: .14em;
    text-decoration: none;
    text-transform: uppercase;
    transform: translateX(-50%);
  }
  .philosophy { padding: clamp(7rem, 13vw, 12rem) 0; text-align: center; background: #f6f3ed; }
  .philosophy-inner { max-width: 920px; }
  .philosophy h2, .stories-heading h2, .promise h2, .closing h2 {
    font-size: 4.2rem;
    line-height: 1.04;
  }
  .philosophy-inner > p:not(.section-kicker) { max-width: 720px; margin: 2rem auto 0; color: var(--color-subtle); font-size: 1.05rem; }
  .journey-steps { display: flex; justify-content: center; gap: 3rem; margin-top: 3.5rem; color: var(--color-accent-dark); font-size: .72rem; font-weight: 600; letter-spacing: .12em; text-transform: uppercase; }
  .stories { padding: 8rem 0 0; background: #fff; }
  .stories-heading { margin-bottom: 5rem; text-align: center; }
  .story-chapter { display: grid; grid-template-columns: 58% 42%; min-height: 650px; }
  .story-chapter.reverse { grid-template-columns: 42% 58%; }
  .story-chapter.reverse .chapter-image { order: 2; }
  .chapter-image { overflow: hidden; display: grid; place-items: center; background: #edf0ec; }
  .chapter-image img { width: 70%; height: 70%; object-fit: contain; transition: transform .7s ease; }
  .chapter-image:hover img { transform: scale(1.05); }
  .chapter-copy { display: flex; flex-direction: column; justify-content: center; padding: clamp(3rem, 7vw, 8rem); background: #e7e1d7; }
  .story-chapter.reverse .chapter-copy { background: #263a38; color: #fff; }
  .chapter-copy h3 { max-width: 600px; font-size: 3.6rem; line-height: 1.02; }
  .chapter-copy > p:not(.section-kicker) { max-width: 480px; margin-top: 1.5rem; font-size: 1rem; line-height: 1.8; }
  .promise { padding: clamp(7rem, 11vw, 10rem) 0; background: #f6f3ed; }
  .promise-grid { display: grid; grid-template-columns: .9fr 1.1fr; gap: 7rem; }
  .promise-list { border-top: 1px solid #cfc7ba; }
  .promise-list div { display: grid; grid-template-columns: 150px 1fr; gap: 2rem; padding: 1.5rem 0; border-bottom: 1px solid #cfc7ba; }
  .promise-list span { font-family: var(--font-serif); font-size: 1.25rem; }
  .promise-list p { color: var(--color-muted); }
  .brands { padding: 4rem 0; background: #fff; text-align: center; }
  .brand-line { display: flex; flex-wrap: wrap; justify-content: center; gap: 1.4rem 3rem; color: #57534d; font-family: var(--font-serif); font-size: 1.15rem; }
  .closing { min-height: 620px; display: grid; place-items: center; color: #fff; text-align: center; background: #263a38; }
  .closing-inner { max-width: 850px; }
  @media (max-width: 800px) {
    .journey-hero { min-height: 760px; }
    .hero-watch { background-position: center 18%; background-size: 330px auto, cover; }
    .hero-shade { background: linear-gradient(0deg, rgba(15,27,25,.88) 0%, rgba(15,27,25,.08) 70%); }
    .hero-content { padding-bottom: 7rem; }
    .hero-content h1 { font-size: 3.3rem; }
    .philosophy h2, .stories-heading h2, .promise h2, .closing h2 { font-size: 2.8rem; }
    .chapter-copy h3 { font-size: 2.5rem; }
    .hero-intro { font-size: .95rem; }
    .journey-steps { gap: 1rem; flex-wrap: wrap; }
    .story-chapter, .story-chapter.reverse { grid-template-columns: 1fr; min-height: 0; }
    .story-chapter.reverse .chapter-image { order: 0; }
    .chapter-image { min-height: 430px; }
    .chapter-copy { min-height: 440px; padding: 3rem 1.5rem; }
    .promise-grid { grid-template-columns: 1fr; gap: 3rem; }
    .promise-list div { grid-template-columns: 1fr; gap: .4rem; }
  }
</style>
