---
import BaseLayout from '../layouts/BaseLayout.astro';
import products from '../data/products.json';

const storyWatch = products.find((p) => p.sku === 'SRE020J1') || products[0];
const brands = [...new Set(products.map((p) => p.brand).filter(Boolean))].slice(0, 8);
const storyCards = [
  {
    label: 'Evening watch',
    brand: 'Seiko',
    title: 'The Seiko Cocktail',
    href: '/stories/seiko-presage-cocktail.html',
    image: 'https://cdnstatic.creationwatches.com/products/product-images/l/SRE020J1_LRG.webp',
    note: 'A champagne dial, cocktail-hour light, and the quiet romance of Presage.',
  },
  {
    label: 'Field legend',
    brand: 'Hamilton',
    title: 'Khaki Field Titanium',
    href: '/stories/khaki-field-titanium.html',
    image: 'https://cdnstatic.creationwatches.com/products/product-images/l/H70205830_LRG.webp',
    note: 'A lightweight field watch built around utility, endurance, and restraint.',
  },
  {
    label: 'Dive story',
    brand: 'Hamilton',
    title: 'Khaki Navy Scuba',
    href: '/stories/khaki-navy-scuba.html',
    image: 'https://cdnstatic.creationwatches.com/products/product-images/l/H82365141_LRG.webp',
    note: 'A clean everyday diver with enough character to carry a weekend.',
  },
  {
    label: 'Racing time',
    brand: 'Tissot',
    title: 'T-Race Chronograph',
    href: '/stories/t-race-chronograph-t048.html',
    image: 'https://cdnstatic.creationwatches.com/products/product-images/l/T048.427.27.057.00_LRG.webp',
    note: 'Motorsport energy, mechanical timing, and a wrist presence that moves.',
  },
];
---

<BaseLayout title="Watch Stories" description="Editorial watch stories, buying guides, and CreationWatches price links for collectors and first-time buyers.">
  <section class="home-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Editorial watch guides</p>
        <h1>See the watch. Read its story. Then decide.</h1>
        <p>
          Watch Stories is a global editorial path, not a storefront. Readers
          first meet a watch visually, then learn the heritage, use case, and
          feeling behind it before any buying link appears.
        </p>
        <div class="hero-actions">
          <a href="/stories/seiko-presage-cocktail.html" class="btn btn-primary">Read the spotlight story</a>
          <a href="#stories" class="btn">Browse story picks</a>
        </div>
      </div>

      {storyWatch && (
        <a href="/stories/seiko-presage-cocktail.html" class="hero-watch" aria-label="Read the Seiko Presage story">
          <span class="hero-watch-label">Story spotlight</span>
          <img src={storyWatch.image} alt={storyWatch.name} />
          <span class="hero-watch-brand">{storyWatch.brand}</span>
          <strong>The Seiko Cocktail: a toast to time</strong>
          <span class="hero-watch-price">Read the story</span>
        </a>
      )}
    </div>
  </section>

  <section class="beliefs">
    <div class="container beliefs-grid">
      <div>
        <p class="eyebrow">Why stories</p>
        <h2>An editorial funnel, not a storefront.</h2>
      </div>
      <div class="belief-list">
        <article>
          <span>01</span>
          <h3>See</h3>
          <p>A strong watch image creates the first moment of curiosity.</p>
        </article>
        <article>
          <span>02</span>
          <h3>Read</h3>
          <p>The story explains heritage, use case, mood, and why the watch matters.</p>
        </article>
        <article>
          <span>03</span>
          <h3>Buy</h3>
          <p>The CreationWatches CTA appears after the reader has context and intent.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="featured" id="stories">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Story picks</p>
          <h2>Watches worth a closer look</h2>
        </div>
        <a href="/watches" class="text-link">View all {products.length} watches</a>
      </div>

      <div class="story-grid">
        {storyCards.map((story) => (
          <a href={story.href} class="story-card">
            <div class="story-image">
              <span>{story.label}</span>
              <img src={story.image} alt={`${story.brand} ${story.title}`} loading="lazy" />
            </div>
            <div class="story-info">
              <span>{story.brand}</span>
              <h3>{story.title}</h3>
              <p>{story.note}</p>
              <strong>Read story</strong>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="brand-strip">
    <div class="container">
      <p class="eyebrow">Brands in the collection</p>
      <div class="brand-list">
        {brands.map((brand) => <span>{brand}</span>)}
      </div>
    </div>
  </section>

  <section class="final-cta">
    <div class="container final-cta-inner">
      <p class="eyebrow">Find yours</p>
      <h2>Start with a story, not a checkout.</h2>
      <p>The site earns trust by letting each watch explain itself before the reader reaches a buying decision.</p>
      <a href="#stories" class="btn btn-primary">Read story picks</a>
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero {
    padding: 6rem 0;
    background: linear-gradient(180deg, var(--color-soft), var(--color-bg));
  }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.75fr);
    gap: 4rem;
    align-items: center;
  }
  .hero-copy p:not(.eyebrow) {
    max-width: 620px;
    margin-top: 1.25rem;
    color: var(--color-muted);
    font-size: 1.05rem;
  }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 2rem; }
  .hero-watch {
    display: grid;
    gap: 0.5rem;
    min-height: 520px;
    padding: 2rem;
    color: inherit;
    text-decoration: none;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }
  .hero-watch-label,
  .hero-watch-brand {
    color: var(--color-accent-dark);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .hero-watch img {
    width: 100%;
    height: 320px;
    object-fit: contain;
    align-self: center;
  }
  .hero-watch strong {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 400;
    line-height: 1.35;
  }
  .hero-watch-price {
    color: var(--color-accent-dark);
    font-family: var(--font-serif);
    font-size: 1.1rem;
  }
  .beliefs { padding: var(--spacing-xl) 0; background: var(--color-surface); }
  .beliefs-grid {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 4rem;
    align-items: start;
  }
  .belief-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-border);
  }
  .belief-list article { min-height: 230px; padding: 1.5rem; background: var(--color-surface); }
  .belief-list span {
    display: block;
    margin-bottom: 2.5rem;
    color: var(--color-accent-dark);
    font-family: var(--font-serif);
    font-size: 2rem;
    opacity: 0.45;
  }
  .belief-list p { margin-top: 0.75rem; color: var(--color-muted); font-size: 0.9rem; }
  .featured { padding: var(--spacing-xl) 0; }
  .section-heading {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  .text-link {
    color: var(--color-accent-dark);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
  }
  .story-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }
  .story-card {
    display: flex;
    flex-direction: column;
    min-width: 0;
    color: inherit;
    text-decoration: none;
    background: var(--color-surface);
  }
  .story-image {
    position: relative;
    display: grid;
    place-items: center;
    aspect-ratio: 1;
    padding: 1rem;
    background: #f7f3ed;
  }
  .story-image > span {
    position: absolute;
    top: 0.8rem;
    left: 0.8rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: 0.3rem 0.5rem;
    color: var(--color-accent-dark);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .story-image img { width: 100%; height: 100%; object-fit: contain; transition: transform 0.25s; }
  .story-card:hover .story-image img { transform: scale(1.04); }
  .story-info { display: grid; gap: 0.5rem; padding: 1rem; }
  .story-info span {
    color: var(--color-accent-dark);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .story-info h3 {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.35;
  }
  .story-info p {
    color: var(--color-muted);
    font-size: 0.86rem;
    line-height: 1.55;
  }
  .story-info strong {
    color: var(--color-accent-dark);
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 600;
  }
  .brand-strip { padding: 4rem 0; background: var(--color-surface); border-block: 1px solid var(--color-border); }
  .brand-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }
  .brand-list span {
    border: 1px solid var(--color-border);
    padding: 0.55rem 0.85rem;
    background: var(--color-bg);
    color: var(--color-subtle);
    font-size: 0.85rem;
  }
  .final-cta { padding: var(--spacing-xl) 0; text-align: center; }
  .final-cta-inner { max-width: 720px; }
  .final-cta p:not(.eyebrow) { margin: 1rem auto 2rem; color: var(--color-muted); max-width: 540px; }

  @media (max-width: 980px) {
    .hero-grid, .beliefs-grid { grid-template-columns: 1fr; }
    .hero-watch { min-height: auto; }
    .story-grid { grid-template-columns: repeat(2, 1fr); }
    .belief-list { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) {
    .home-hero { padding: 4rem 0; }
    .hero-grid { gap: 2rem; }
    .hero-watch { padding: 1rem; }
    .hero-watch img { height: 240px; }
    .section-heading { align-items: start; flex-direction: column; }
    .story-grid { grid-template-columns: 1fr; }
  }
</style>
