---
import BaseLayout from '../layouts/BaseLayout.astro';
import products from '../data/products.json';

const storyWatch = products.find((p) => p.sku === 'SRE020J1') || products[0];
const featured = products.slice(0, 8);
const brands = [...new Set(products.map((p) => p.brand).filter(Boolean))].slice(0, 8);
---

<BaseLayout title="Watch Stories" description="Editorial watch stories, buying guides, and CreationWatches price links for collectors and first-time buyers.">
  <section class="home-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Editorial watch guides</p>
        <h1>Stories that help readers choose their next watch.</h1>
        <p>
          Watch Stories is built as a quiet buying companion: we explain the
          heritage, use case, and appeal of each watch, then send ready buyers
          to CreationWatches to check current pricing.
        </p>
        <div class="hero-actions">
          <a href="/watches" class="btn btn-primary">Read buying guides</a>
          <a href="/stories/seiko-presage-cocktail.html" class="btn">Read a story</a>
        </div>
      </div>

      {storyWatch && (
        <a href="/stories/seiko-presage-cocktail.html" class="hero-watch" aria-label="Read the Seiko Presage story">
          <span class="hero-watch-label">Story spotlight</span>
          <img src={storyWatch.image} alt={storyWatch.name} />
          <span class="hero-watch-brand">{storyWatch.brand}</span>
          <strong>{storyWatch.name}</strong>
          <span class="hero-watch-price">${storyWatch.price_usd?.toFixed(2)}</span>
        </a>
      )}
    </div>
  </section>

  <section class="beliefs">
    <div class="container beliefs-grid">
      <div>
        <p class="eyebrow">Why stories</p>
        <h2>An editorial funnel, not a storefront.</h2>
      </div>
      <div class="belief-list">
        <article>
          <span>01</span>
          <h3>Heritage</h3>
          <p>Give search traffic a reason to stay with stories, context, and brand background.</p>
        </article>
        <article>
          <span>02</span>
          <h3>Purpose</h3>
          <p>Frame each watch by use case: work, travel, milestone gifts, daily wear, or collecting.</p>
        </article>
        <article>
          <span>03</span>
          <h3>Clarity</h3>
          <p>Move interested readers toward a single action: check the current price at CreationWatches.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="featured">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Affiliate guides</p>
          <h2>Watches worth reading about</h2>
        </div>
        <a href="/watches" class="text-link">View all {products.length} watches</a>
      </div>

      <div class="product-grid">
        {featured.map((product) => (
          <a href={product.url || '/watches'} class="product-card" target="_blank" rel="noopener noreferrer">
            <div class="product-image">
              <img src={product.image} alt={product.name} loading="lazy" />
            </div>
            <div class="product-info">
              <span>{product.brand}</span>
              <h3>{product.name}</h3>
              <strong>{product.price_usd > 0 ? `$${product.price_usd.toFixed(2)}` : 'View details'}</strong>
              <small>Check price at CreationWatches</small>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="brand-strip">
    <div class="container">
      <p class="eyebrow">Brands in the collection</p>
      <div class="brand-list">
        {brands.map((brand) => <span>{brand}</span>)}
      </div>
    </div>
  </section>

  <section class="final-cta">
    <div class="container final-cta-inner">
      <p class="eyebrow">Find yours</p>
      <h2>Turn watch research into affiliate clicks.</h2>
      <p>Start with the story, answer the buying questions, then send readers to CreationWatches when intent is highest.</p>
      <a href="/watches" class="btn btn-primary">Browse the guides</a>
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero {
    padding: 6rem 0;
    background: linear-gradient(180deg, var(--color-soft), var(--color-bg));
  }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.75fr);
    gap: 4rem;
    align-items: center;
  }
  .hero-copy p:not(.eyebrow) {
    max-width: 620px;
    margin-top: 1.25rem;
    color: var(--color-muted);
    font-size: 1.05rem;
  }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 2rem; }
  .hero-watch {
    display: grid;
    gap: 0.5rem;
    min-height: 520px;
    padding: 2rem;
    color: inherit;
    text-decoration: none;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }
  .hero-watch-label,
  .hero-watch-brand {
    color: var(--color-accent-dark);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .hero-watch img {
    width: 100%;
    height: 320px;
    object-fit: contain;
    align-self: center;
  }
  .hero-watch strong {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 400;
    line-height: 1.35;
  }
  .hero-watch-price {
    color: var(--color-accent-dark);
    font-family: var(--font-serif);
    font-size: 1.1rem;
  }
  .beliefs { padding: var(--spacing-xl) 0; background: var(--color-surface); }
  .beliefs-grid {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 4rem;
    align-items: start;
  }
  .belief-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-border);
  }
  .belief-list article { min-height: 230px; padding: 1.5rem; background: var(--color-surface); }
  .belief-list span {
    display: block;
    margin-bottom: 2.5rem;
    color: var(--color-accent-dark);
    font-family: var(--font-serif);
    font-size: 2rem;
    opacity: 0.45;
  }
  .belief-list p { margin-top: 0.75rem; color: var(--color-muted); font-size: 0.9rem; }
  .featured { padding: var(--spacing-xl) 0; }
  .section-heading {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  .text-link {
    color: var(--color-accent-dark);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
  }
  .product-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }
  .product-card {
    display: flex;
    flex-direction: column;
    min-width: 0;
    color: inherit;
    text-decoration: none;
    background: var(--color-surface);
  }
  .product-image {
    display: grid;
    place-items: center;
    aspect-ratio: 1;
    padding: 1rem;
    background: #f7f3ed;
  }
  .product-image img { width: 100%; height: 100%; object-fit: contain; transition: transform 0.25s; }
  .product-card:hover .product-image img { transform: scale(1.04); }
  .product-info { display: grid; gap: 0.35rem; padding: 1rem; }
  .product-info span {
    color: var(--color-accent-dark);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .product-info h3 {
    display: -webkit-box;
    min-height: 3.2em;
    overflow: hidden;
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-weight: 400;
    line-height: 1.6;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .product-info strong {
    color: var(--color-accent-dark);
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 600;
  }
  .product-info small {
    color: var(--color-muted);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .brand-strip { padding: 4rem 0; background: var(--color-surface); border-block: 1px solid var(--color-border); }
  .brand-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }
  .brand-list span {
    border: 1px solid var(--color-border);
    padding: 0.55rem 0.85rem;
    background: var(--color-bg);
    color: var(--color-subtle);
    font-size: 0.85rem;
  }
  .final-cta { padding: var(--spacing-xl) 0; text-align: center; }
  .final-cta-inner { max-width: 720px; }
  .final-cta p:not(.eyebrow) { margin: 1rem auto 2rem; color: var(--color-muted); max-width: 540px; }

  @media (max-width: 980px) {
    .hero-grid, .beliefs-grid { grid-template-columns: 1fr; }
    .hero-watch { min-height: auto; }
    .product-grid { grid-template-columns: repeat(2, 1fr); }
    .belief-list { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) {
    .home-hero { padding: 4rem 0; }
    .hero-grid { gap: 2rem; }
    .hero-watch { padding: 1rem; }
    .hero-watch img { height: 240px; }
    .section-heading { align-items: start; flex-direction: column; }
    .product-grid { grid-template-columns: 1fr; }
  }
</style>
