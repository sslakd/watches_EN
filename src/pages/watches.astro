---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="All Watches" description="Browse our curated collection of watches — each with a story waiting to be told.">
  <div class="hero">
    <div class="subtitle">The Collection</div>
    <h1>Find Your Story</h1>
    <p>Browse our curated selection of timepieces. Every watch we feature has been chosen for its craftsmanship, heritage, and the story it tells.</p>
  </div>

  <div class="card-grid" id="watches-grid"></div>

  <div style="text-align: center; padding: var(--spacing-xl) 0;">
    <p style="color: var(--color-muted); font-style: italic;">More stories being added daily. Check back soon.</p>
  </div>
</BaseLayout>
