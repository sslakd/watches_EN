---
import BaseLayout from '../layouts/BaseLayout.astro';
import products from '../data/products.json';

const visibleProducts = products.slice(0, 48);
const priceGroups = [
  { label: 'Under $100', range: 'Everyday picks', watches: products.filter((p) => p.price_usd > 0 && p.price_usd < 100).slice(0, 4) },
  { label: '$100 to $300', range: 'Strong value', watches: products.filter((p) => p.price_usd >= 100 && p.price_usd < 300).slice(0, 4) },
  { label: '$300+', range: 'Collector focus', watches: products.filter((p) => p.price_usd >= 300).slice(0, 4) },
].filter((group) => group.watches.length > 0);
---

<BaseLayout title="All Watches" description="Browse the Watch Stories collection by price, brand, and product story.">
  <section class="page-hero collection-hero">
    <div class="container">
      <p class="eyebrow">The collection</p>
      <h1>{products.length} watches, clearly organized.</h1>
      <p>
        Browse practical daily watches, value-focused automatics, and collector pieces
        from the same simple product view.
      </p>
    </div>
  </section>

  <section class="price-groups">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Start by budget</p>
          <h2>Price ranges</h2>
        </div>
      </div>

      <div class="group-grid">
        {priceGroups.map((group) => (
          <section class="group-panel">
            <div class="group-header">
              <span>{group.range}</span>
              <h3>{group.label}</h3>
            </div>
            <div class="mini-list">
              {group.watches.map((watch) => (
                <a href={watch.url || '#'} class="mini-card" target="_blank" rel="noopener noreferrer">
                  <img src={watch.image} alt={watch.name} loading="lazy" />
                  <div>
                    <span>{watch.brand}</span>
                    <strong>{watch.name}</strong>
                    <em>{watch.price_usd > 0 ? `$${watch.price_usd.toFixed(2)}` : 'View details'}</em>
                  </div>
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>
  </section>

  <section class="all-watches">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Curated feed</p>
          <h2>All watches</h2>
        </div>
        <span class="count">{visibleProducts.length} shown</span>
      </div>

      <div class="watch-grid">
        {visibleProducts.map((watch) => (
          <a href={watch.url || '#'} class="watch-card" target="_blank" rel="noopener noreferrer">
            <div class="watch-image">
              {watch.price_usd > 0 && watch.price_usd < 100 && <span class="badge">Value</span>}
              <img src={watch.image} alt={watch.name} loading="lazy" />
            </div>
            <div class="watch-info">
              <span>{watch.brand}</span>
              <h3>{watch.name}</h3>
              <strong>{watch.price_usd > 0 ? `$${watch.price_usd.toFixed(2)}` : 'View details'}</strong>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .collection-hero {
    background: linear-gradient(180deg, var(--color-soft), var(--color-bg));
  }
  .price-groups { padding: var(--spacing-xl) 0; background: var(--color-surface); }
  .section-heading {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  .count {
    color: var(--color-muted);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .group-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }
  .group-panel { background: var(--color-surface); }
  .group-header { padding: 1.25rem; border-bottom: 1px solid var(--color-border); }
  .group-header span {
    color: var(--color-accent-dark);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .group-header h3 { margin-top: 0.35rem; }
  .mini-list { display: grid; }
  .mini-card {
    display: grid;
    grid-template-columns: 74px 1fr;
    gap: 0.9rem;
    min-width: 0;
    padding: 1rem 1.25rem;
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
  }
  .mini-card:last-child { border-bottom: 0; }
  .mini-card:hover { background: var(--color-bg); }
  .mini-card img {
    width: 74px;
    height: 74px;
    object-fit: contain;
    background: var(--color-soft);
  }
  .mini-card div { min-width: 0; display: grid; gap: 0.2rem; align-content: center; }
  .mini-card span,
  .watch-info span {
    color: var(--color-accent-dark);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .mini-card strong {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 0.86rem;
    font-weight: 400;
  }
  .mini-card em {
    color: var(--color-accent-dark);
    font-family: var(--font-serif);
    font-size: 0.96rem;
    font-style: normal;
  }
  .all-watches { padding: var(--spacing-xl) 0 var(--spacing-2xl); }
  .watch-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }
  .watch-card {
    display: flex;
    flex-direction: column;
    min-width: 0;
    color: inherit;
    text-decoration: none;
    background: var(--color-surface);
  }
  .watch-image {
    position: relative;
    display: grid;
    place-items: center;
    aspect-ratio: 1;
    padding: 1rem;
    background: #f7f3ed;
  }
  .watch-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.25s;
  }
  .watch-card:hover .watch-image img { transform: scale(1.04); }
  .badge {
    position: absolute;
    top: 0.7rem;
    left: 0.7rem;
    z-index: 1;
    background: var(--color-text);
    color: white;
    padding: 0.25rem 0.45rem;
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .watch-info { display: grid; gap: 0.35rem; padding: 1rem; }
  .watch-info h3 {
    display: -webkit-box;
    min-height: 3.2em;
    overflow: hidden;
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-weight: 400;
    line-height: 1.6;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .watch-info strong {
    color: var(--color-accent-dark);
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 600;
  }

  @media (max-width: 1040px) {
    .group-grid { grid-template-columns: 1fr; }
    .watch-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 720px) {
    .section-heading { align-items: start; flex-direction: column; }
    .watch-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .watch-grid { grid-template-columns: 1fr; }
  }
</style>
