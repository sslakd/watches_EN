---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="All Watches" description="Browse our curated collection of watches — each with a story waiting to be told.">
  <div class="hero">
    <div class="subtitle">The Collection</div>
    <h1>Find Your Story</h1>
    <p>Browse our curated selection of timepieces. Every watch we feature has been chosen for its craftsmanship, heritage, and the story it tells.</p>
  </div>

  <div class="card-grid" id="watches-grid"></div>

  <div style="text-align: center; padding: var(--spacing-xl) 0;">
    <p style="color: var(--color-muted); font-style: italic;">More stories being added daily. Check back soon.</p>
  </div>
</BaseLayout>

<script>
  (async () => {
    try {
      const res = await fetch('/data/products.json');
      const products = await res.json();
      const grid = document.getElementById('watches-grid');
      if (!grid || !products.length) return;

      grid.innerHTML = products.map(p => {
        const img = p.image
          ? `<img src="${p.image}" alt="${p.name}" loading="lazy" />`
          : `<div style="background:#e8e3dd;width:100%;aspect-ratio:1;display:flex;align-items:center;justify-content:center;color:#888;font-size:0.85rem;">No Image</div>`;
        const price = p.price_usd > 0 ? `$${p.price_usd.toFixed(2)}` : '';
        return `<a href="${p.url}" class="card" target="_blank" rel="noopener">
          ${img}
          <div class="brand">${p.brand || ''}</div>
          <h3>${p.name}</h3>
          <div class="price">${price}</div>
        </a>`;
      }).join('');
    } catch(e) {
      console.warn('Failed to load products:', e);
    }
  })();
</script>