---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="The story behind Watch Stories and why every timepiece has a narrative worth sharing.">
  <section class="page-hero about-hero">
    <div class="container">
      <p class="eyebrow">Our story</p>
      <h1>Why Watch Stories?</h1>
      <p>
        A watch is never just a watch. It can be the first gift you gave yourself,
        the heirloom someone trusted you with, or the marker of a milestone.
      </p>
    </div>
  </section>

  <section class="about-body">
    <div class="container about-grid">
      <div>
        <p class="eyebrow">Our point of view</p>
        <h2>The right watch should be easier to understand.</h2>
      </div>
      <div class="about-copy">
        <p>
          Our curated collection brings together timepieces from respected brands
          such as Seiko, Citizen, Casio, Orient, and more. We focus on watches
          that have something to say through design, function, or heritage.
        </p>
        <p>
          Whether you are a collector, a first-time buyer, or someone looking for
          a meaningful gift, Watch Stories is built to make discovery calmer,
          clearer, and more personal.
        </p>
        <p class="signature">The Watch Stories Team</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero { background: linear-gradient(180deg, var(--color-soft), var(--color-bg)); }
  .about-body { padding: var(--spacing-xl) 0 var(--spacing-2xl); }
  .about-grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 4rem;
    align-items: start;
  }
  .about-copy {
    display: grid;
    gap: 1.25rem;
    color: var(--color-subtle);
    font-size: 1rem;
    line-height: 1.9;
  }
  .signature {
    color: var(--color-accent-dark);
    font-family: var(--font-serif);
    font-size: 1.15rem;
  }
  @media (max-width: 760px) {
    .about-grid { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
