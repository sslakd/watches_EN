---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="Watch Stories is an editorial affiliate site that turns watch research into CreationWatches traffic.">
  <section class="page-hero about-hero">
    <div class="container">
      <p class="eyebrow">Our story</p>
      <h1>Why Watch Stories?</h1>
      <p>
        Watch Stories is an editorial affiliate site. We use stories, buying context,
        and brand heritage to help readers decide which watch is worth opening at
        CreationWatches.
      </p>
    </div>
  </section>

  <section class="about-body">
    <div class="container about-grid">
      <div>
        <p class="eyebrow">Our point of view</p>
        <h2>We write for readers before they click the affiliate link.</h2>
      </div>
      <div class="about-copy">
        <p>
          Our job is not to look like another store. It is to earn search traffic
          with useful watch stories, explain why a model matters, and give readers
          a clear next step when they are ready to compare the current price.
        </p>
        <p>
          Product links may point to CreationWatches. When readers buy through
          those links, we may earn an affiliate commission at no extra cost to them.
        </p>
        <p class="signature">The Watch Stories Team</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero { background: linear-gradient(180deg, var(--color-soft), var(--color-bg)); }
  .about-body { padding: var(--spacing-xl) 0 var(--spacing-2xl); }
  .about-grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 4rem;
    align-items: start;
  }
  .about-copy {
    display: grid;
    gap: 1.25rem;
    color: var(--color-subtle);
    font-size: 1rem;
    line-height: 1.9;
  }
  .signature {
    color: var(--color-accent-dark);
    font-family: var(--font-serif);
    font-size: 1.15rem;
  }
  @media (max-width: 760px) {
    .about-grid { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
